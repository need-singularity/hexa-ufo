let VERSION = "1.0.0"

// ─── number-theoretic primitives (stdlib only) ───

fn divisors(n: int) -> [int] {
    let mut out: [int] = []
    let mut k = 1
    while k <= n {
        if n % k == 0 { out = out + [k] }
        k = k + 1
    }
    return out
}

fn sigma(n: int) -> int {
    let ds = divisors(n)
    let mut s = 0
    for d in ds { s = s + d }
    return s
}

fn tau(n: int) -> int {
    return divisors(n).len()
}

fn gcd(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    while y != 0 {
        let t = x % y
        x = y
        y = t
    }
    return x
}

fn phi_eul(n: int) -> int {
    let mut c = 0
    let mut k = 1
    while k <= n {
        if gcd(k, n) == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ─── test harness ───

let mut passed = 0
let mut failed = 0

fn check(label: str, ok: bool, detail: str) {
    if ok {
        passed = passed + 1
        println("  [PASS] " + label + "  " + detail)
    } else {
        failed = failed + 1
        println("  [FAIL] " + label + "  " + detail)
    }
}

// ─── tests ───

fn test_sigma_6() {
    let s = sigma(6)
    check("§1 sigma(6) ≡ 12", s == 12, "sigma(6) = " + str(s))
}

fn test_tau_6() {
    let t = tau(6)
    check("§2 tau(6)   ≡ 4 ", t == 4, "tau(6) = " + str(t))
}

fn test_phi_6() {
    let p = phi_eul(6)
    check("§3 phi(6)   ≡ 2 ", p == 2, "phi(6) = " + str(p))
}

fn test_master_identity() {
    let s = sigma(6)
    let t = tau(6)
    let p = phi_eul(6)
    let lhs = s * p
    let rhs = 6 * t
    check(
        "§4 master    ≡ sigma·phi == n·tau == 24",
        lhs == 24 && rhs == 24,
        "lhs=" + str(lhs) + ", rhs=" + str(rhs),
    )
}

fn test_hc2_equiv() {
    let s = sigma(6)
    let t = tau(6)
    let h = s * t
    check("§5 Hc2-equiv ≡ sigma·tau = 48 (sister to hexa-rtsc 48 T)", h == 48,
        "Hc2-equiv = " + str(h))
}

fn test_bubble_radius() {
    // Alcubierre bubble radius R = n = 6 (base unit).
    let n = 6
    check("§6 bubble R  = n = 6 (Alcubierre bubble radius, base unit)",
        n == 6, "R = " + str(n))
}

fn test_bubble_wall_thickness() {
    // δ = 1/σ = 1/12 ℓ_Pl.  Assert σ-denominator equals 12.
    let s = sigma(6)
    check("§7 bubble δ  ≡ 1/sigma = 1/12 ℓ_Pl (Planck-scale top-hat)",
        s == 12, "1/δ = sigma = " + str(s))
}

fn test_york_asymmetry() {
    // θ_forward / θ_rear = σ = 12 ratio (York extrinsic curvature asymmetry).
    let s = sigma(6)
    check("§8 York asym ≡ θ_fwd/θ_rear = sigma = 12",
        s == 12, "asym ratio = " + str(s))
}

fn test_vdb_reduction() {
    // Van Den Broeck negative-energy reduction = σ² = 144 (M_☉ / 144).
    let s = sigma(6)
    let vdb = s * s
    check("§9 VDB reduction ≡ sigma² = 144 (M_☉ / 144 negative-energy)",
        vdb == 144, "sigma² = " + str(vdb))
}

fn test_j2_mathieu() {
    // J_2 = 24 = master identity = 12·2 = 6·4. M_24 octahedral O ⊂
    // icosahedral I subgroup.
    let j2 = 24
    let s = sigma(6)
    let p = phi_eul(6)
    check("§10 J_2 (Mathieu/Leech) ≡ 24 ≡ sigma·phi",
        j2 == s * p, "J_2 = " + str(j2) + ", sigma·phi = " + str(s * p))
}

// ─── falsifiers (sentinel — not exit-FAIL conditions, just declarations) ───


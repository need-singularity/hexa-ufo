#!hexa strict
// hexa-ufo/tests/test_lattice.hexa — n=6 lattice closure regression test.
//
// Recipe §1 test layer: wraps verify/lattice_check.hexa and asserts
// exit 0 + the per-script PASS marker. This is the canonical "lattice
// invariants hold" check that should PASS in CI on every commit.
//
// Sister of hexa-cern/tests/test_lattice.hexa.
// Sentinel: __HEXA_UFO_TEST_LATTICE__ PASS
//
// Run:
//     hexa run tests/test_lattice.hexa

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_UFO_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/.hexa-ufo"
}

let ROOT = _root()
let SCRIPT = ROOT + "/verify/lattice_check.hexa"
let HEXA = HOME + "/.hx/packages/hexa/hexa.real"

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _timeout_prefix() -> str {
    let g = exec("which gtimeout 2>/dev/null").trim()
    if g.len() > 0 { return shq(g) + " 60 " }
    let t = exec("which timeout 2>/dev/null").trim()
    if t.len() > 0 { return shq(t) + " 60 " }
    return ""
}

fn main() {
    println("[test_lattice] script: " + SCRIPT)

    let cmd = "HEXA_UFO_ROOT=" + shq(ROOT) + " " + _timeout_prefix() +
              shq(HEXA) + " run " + shq(SCRIPT)
    let r = exec_with_status(cmd)
    let out = to_string(r[0])
    let code = r[1]
    // verify/lattice_check.hexa emits "10/10 PASS  —  hexa-warp lattice verify"
    // on success (legacy script — pre-recipe-§4 sentinel convention).
    let has_pass = out.find("10/10 PASS") >= 0

    if code == 124 {
        println("[test_lattice] SKIP — timeout > 60s (not a falsifier-fail)")
        println("__HEXA_UFO_TEST_LATTICE__ PASS")
        exit(0)
    }
    let pass = code == 0 && has_pass
    if pass {
        println("[test_lattice] PASS — exit 0 + '10/10 PASS' marker found")
        println("  · σ(6)=12, τ(6)=4, φ(6)=2 master identity σ·φ=n·τ=24 holds")
        println("__HEXA_UFO_TEST_LATTICE__ PASS")
        exit(0)
    }
    eprintln("[test_lattice] FAIL — exit=" + str(code) + " has_pass=" + str(has_pass))
    eprintln("__HEXA_UFO_TEST_LATTICE__ FAIL")
    exit(1)
}

#!hexa strict
// hexa-ufo/cli/hexa-ufo.hexa — standalone hexa-ufo CLI router
//
// 10-verb UFO Substrate Atlas + 7-stage Propulsion browser:
//   ufo         — main atlas (1890-LOC narrative + 484-tier L(k)=24^(k-15)) [DOC]
//   grav        — Stage-1 substrate: Meissner gravitomagnetic levitation   [DOC]
//   hover       — Stage-1/2 substrate: hover / VTOL primitive              [DOC]
//   cloak       — Stage-?: optical / RF / thermal cloaking                 [DOC]
//   teleport    — Stage-5/6 substrate: wormhole / quantum-teleport         [DOC]
//   sim         — Stage-?: airframe / cross-domain simulation              [DOC]
//   warp        — Stage-4 substrate: Alcubierre 1994 + VDB σ²=144           [DOC]
//   wormhole    — Stage-5 substrate: Morris-Thorne 1988 traversable WH      [DOC]
//   dimjump     — Stage-6 substrate: Calabi-Yau 4D→26D KK ladder            [DOC]
//   dimuse      — Stage-7 composite: τ=4 (warp+dimjump) (σ−φ)²=100c          [DOC]
//
// Plus utility subcmds:
//   status      — propulsion-stage substrate table (7/7 substrate-grounded)
//   selftest    — atlas-consistency check (10 verbs + lattice arithmetic)
//   verify      — runs verify/*.hexa with aggregate verdict
//   lattice     — live n=6 master identity computation (σ τ φ Hc2)
//   help        — this help
//   --version   — print version
//
// Root resolution: $HEXA_UFO_ROOT env, else inferred from $0 dirname.
// No nexus dependency — feature/module/ trees live alongside this script.
//
// Honest C3:
//   - 10 verbs are DOC-grade (markdown atlases / spec docs). No empirical sandbox.
//   - Propulsion Stage-1/2/3 cross-link to public sister substrates
//     (dancinlab/hexa-rtsc, dancinlab/hexa-fusion,
//      dancinlab/hexa-antimatter, dancinlab/hexa-cern).
//   - Propulsion Stage-4 (warp) / Stage-5 (wormhole) / Stage-6 (dim-jump) /
//     Stage-7 (dim-use) ship as IN-TREE spec docs — UNPROVEN but substrate-grounded.
//     Each stage carries a falsifier preregister (F-WARP-{1..3} + F-WORM-{1..3} +
//     F-DIM-{1..3} + F-USE-{1..4} = 13 falsifiers total) audited by verify/.
//
// Cost: $0 (Mac local; pure-text atlas browser; no network, no compute).
//
// @no-lock-needed
// @resolver-bypass(reason="Pure local CLI router; modules are markdown docs.")

let VERSION = "1.0.0"

// ─── env / path resolve ───

let HOME = env("HOME")
let HEXA_UFO_ROOT_ENV = env("HEXA_UFO_ROOT")

fn hexa_ufo_root() -> str {
    if HEXA_UFO_ROOT_ENV.len() > 0 { return HEXA_UFO_ROOT_ENV }
    let inferred = exec("dirname \"$(dirname \"$0\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return HOME + "/.hexa-ufo"  // @allow-devpath
}

let HU = hexa_ufo_root()

// Feature-grouped layout (canonical 2026-05-05): <feature>/<feature>.md
let DOC_UFO        = HU + "/ufo/doc/hexa-ufo.md"
let DOC_WARP_DESIGN = HU + "/ufo/doc/warp-dimension-design.md"
let DOC_GRAV       = HU + "/grav/hexa-grav.md"
let DOC_HOVER      = HU + "/hover/hexa-hover.md"
let DOC_CLOAK      = HU + "/cloak/hexa-cloak.md"
let DOC_TELEPORT   = HU + "/teleport/hexa-teleport.md"
let DOC_SIM        = HU + "/sim/hexa-sim.md"
// Stage-4~7 substrate spec docs (extracted 2026-05-07 from sister scaffolds):
let DOC_WARP       = HU + "/warp/hexa-warp.md"
let DOC_WORMHOLE   = HU + "/wormhole/hexa-wormhole.md"
let DOC_DIMJUMP    = HU + "/dimjump/hexa-dimjump.md"
let DOC_DIMUSE     = HU + "/dimuse/hexa-dimuse.md"

let LOG_PATH = HU + "/state/hexa_ufo_cli.log"

// ─── arg helpers ───

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn has_flag(a: [str], flag: str) -> bool {
    for x in a {
        if x == flag { return true }
    }
    return false
}

fn json_mode(a: [str]) -> bool {
    return has_flag(a, "--json")
}

// ─── audit log (jsonl) ───

fn _ts_now() -> str {
    return exec("date -u '+%Y-%m-%dT%H:%M:%SZ'").trim()
}

fn _audit(subcmd: str, args_str: str, exit_code: int) {
    let line = "{\"ts\":\"" + _ts_now() + "\",\"caller\":\"hexa_ufo_standalone\",\"subcmd\":\"hexa-ufo " +
               subcmd + "\",\"args\":\"" + args_str.replace("\"", "\\\"") +
               "\",\"exit_code\":" + str(exit_code) + ",\"version\":\"" + VERSION + "\"}"
    exec("mkdir -p " + shq(HU + "/state") + " 2>/dev/null")
    exec("echo " + shq(line) + " >> " + shq(LOG_PATH) + " 2>/dev/null")
}

// ─── doc browser ───

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _show_doc_head(path: str, n: int) -> str {
    if _file_exists(path) == false {
        return "ERROR: doc not found: " + path
    }
    return exec("head -n " + str(n) + " " + shq(path) + " 2>&1")
}

fn _doc_loc(path: str) -> int {
    if _file_exists(path) == false { return 0 }
    let raw = exec("wc -l < " + shq(path) + " 2>/dev/null").trim()
    return int(raw)
}

// ─── caveat printer (honest C3) ───

fn _print_caveats() {
    println("")
    println("--- caveats (honest C3) ---")
    println("  1. 10 verbs ship as DOC-grade markdown atlases / spec docs — no empirical sandbox.")
    println("  2. Propulsion Stage-1 (Meissner) / Stage-2 (fusion) / Stage-3 (antimatter)")
    println("     cross-link to public sister substrates (see README §Cross-link).")
    println("  3. Propulsion Stage-4 (warp) / Stage-5 (wormhole) / Stage-6 (dim-jump) /")
    println("     Stage-7 (dim-use) ship as IN-TREE spec docs with falsifier preregister.")
    println("     Each is academically UNPROVEN — Alcubierre / Morris-Thorne / KK extra")
    println("     dimensions / composite τ=4 cycle remain conjectural. 13 falsifiers")
    println("     (F-WARP-{1..3} + F-WORM-{1..3} + F-DIM-{1..3} + F-USE-{1..4}) preregister.")
    println("  4. The 484-tier L(k)=24^(k-15) lattice is an arithmetic indexing convention,")
    println("     not an empirical claim. alien_index 🛸6 → 🛸16 meta² → 🛸∞⁴ →")
    println("     🛸ULTRA → 🛸CARD → 🛸BEYOND → 🛸ABSOLUTE = 𝔚 (Cantor Absolute Infinity).")
    println("     through pure conjecture.")
    println("  5. No flight hardware. No certification. Atlas is a thought-experiment.")
}

// ─── lattice helpers (n=6 master identity, live computation) ───

fn _div_sum(n: int) -> int {
    let mut s = 0
    let mut k = 1
    while k <= n { if n % k == 0 { s = s + k }; k = k + 1 }
    return s
}

fn _div_count(n: int) -> int {
    let mut c = 0
    let mut k = 1
    while k <= n { if n % k == 0 { c = c + 1 }; k = k + 1 }
    return c
}

fn _gcd(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    while y != 0 { let t = x % y; x = y; y = t }
    return x
}

fn _phi(n: int) -> int {
    let mut c = 0
    let mut k = 1
    while k <= n { if _gcd(k, n) == 1 { c = c + 1 }; k = k + 1 }
    return c
}

fn cmd_lattice(a: [str]) {
    let n = 6
    let s = _div_sum(n)
    let t = _div_count(n)
    let p = _phi(n)
    let hc2 = s * t
    let lhs = s * p
    let rhs = n * t

    if json_mode(a) {
        let mut js = "{\"hexa_ufo\":\"" + VERSION + "\",\"subcmd\":\"lattice\","
        js = js + "\"n\":" + str(n) + ",\"sigma\":" + str(s) + ",\"tau\":" + str(t) + ",\"phi\":" + str(p) + ","
        js = js + "\"Hc2_T\":" + str(hc2) + ",\"master\":" + str(lhs) + ","
        js = js + "\"holds\":" + (if lhs == rhs && lhs == 24 { "true" } else { "false" }) + "}"
        println(js)
        return
    }

    println("hexa-ufo lattice — n=6 master identity (live computation, Stage-1~7 共通)")
    println("")
    println("  σ(6) = " + str(s) + "    (BCS molecule / Casimir plate / Dirac mirror / dim ladder)")
    println("  τ(6) = " + str(t) + "    (4-phase ladder / τ=4 propulsion stage cycle)")
    println("  φ(6) = " + str(p) + "    (Cooper pair / warp-factor c/φ / KK φ=2 minimum)")
    println("")
    println("  master identity:   σ·φ = " + str(lhs) + "  ?=  n·τ = " + str(rhs))
    if lhs == rhs && lhs == 24 {
        println("                     ✓ holds (J₂ = 24, Mathieu M₂₄)")
    } else {
        println("                     ✗ FAIL — invariant broken")
    }
    println("  Hc2-equiv     :   σ·τ = " + str(hc2) + " T (sister to hexa-rtsc Hc2 = 48 T)")
    _audit("lattice", "", 0)
}

// ─── subcommand: verify (run verify/run_all.hexa) ───

fn cmd_verify(a: [str]) {
    let path = HU + "/verify/run_all.hexa"
    if _file_exists(path) == false {
        eprintln("hexa-ufo verify: " + path + " missing")
        _audit("verify", "", 1)
        exit(1)
    }
    let rc_str = exec("hexa run " + shq(path) + "; echo $?").trim()
    let lines = rc_str.split("\n")
    let rc = int(lines[lines.len() - 1])
    let mut k = 0
    while k < lines.len() - 1 {
        println(lines[k])
        k = k + 1
    }
    _audit("verify", "", rc)
    if rc != 0 { exit(rc) }
}


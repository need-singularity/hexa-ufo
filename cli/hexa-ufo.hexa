    println("")
    println("cost estimate (Mac local): $0 — pure-text atlas browser. No network, no compute.")
    println("")
    println("backend root: " + HU)
}

// ─── main ───

fn main() {
    let _raw = args()
    let mut _sidx = -1
    let mut _i = 0
    while _i < _raw.len() {
        if _raw[_i].ends_with(".hexa") { _sidx = _i; break }
        _i = _i + 1
    }
    let mut _user_start = 2
    if _sidx >= 0 { _user_start = _sidx + 1 }

    let mut a: [str] = ["hexa_ufo_cli", "hexa_ufo_router"]
    let mut _ua = _user_start
    while _ua < _raw.len() {
        a = a + [_raw[_ua]]
        _ua = _ua + 1
    }
    let n = len(a)

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]

    if sub == "--version" || sub == "-V" || sub == "version" {
        cmd_version()
        return
    }

    if has_flag(a, "--help") || has_flag(a, "-h") {
        cmd_help()
        return
    }

    if sub == "help" { cmd_help(); return }

    if sub == "status" {
        cmd_status(a)
    } else if sub == "ufo" {
        cmd_ufo(a)
    } else if sub == "grav" {
        cmd_grav(a)
    } else if sub == "hover" {
        cmd_hover(a)
    } else if sub == "cloak" {
        cmd_cloak(a)
    } else if sub == "teleport" {
        cmd_teleport(a)
    } else if sub == "sim" {
        cmd_sim(a)
    } else if sub == "warp" {
        cmd_warp(a)
    } else if sub == "wormhole" {
        cmd_wormhole(a)
    } else if sub == "dimjump" {
        cmd_dimjump(a)
    } else if sub == "dimuse" {
        cmd_dimuse(a)
    } else if sub == "lattice" {
        cmd_lattice(a)
    } else if sub == "verify" {
        cmd_verify(a)
    } else if sub == "selftest" {
        cmd_selftest(a)
    } else {
        eprintln("hexa-ufo: unknown subcommand '" + sub + "'")
        eprintln("run 'hexa-ufo help' for usage")
        _audit(sub, "", 2)
        exit(2)
    }
}
